<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<title>Game of Life — Dépendances</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Segoe UI',system-ui,sans-serif;background:#080812;color:#eee;overflow:hidden;user-select:none;}

#header{
	padding:9px 18px;
	background:linear-gradient(90deg,#0c0c22 0%,#131330 60%,#0e0e28 100%);
	border-bottom:1px solid #1e1e45;
	display:flex;align-items:center;gap:14px;
	box-shadow:0 2px 24px #000c;
	position:relative;z-index:20;
}
#header h1{font-size:13.5px;color:#8ec5ff;font-weight:700;white-space:nowrap;letter-spacing:0.01em;}
#header p{font-size:9.5px;color:#3a3a5a;margin-top:2px;}

.legend{display:flex;gap:7px;flex-wrap:wrap;margin-left:auto;font-size:10px;align-items:center;}
.leg{display:flex;align-items:center;gap:4px;cursor:default;padding:3px 6px;border-radius:5px;transition:background 0.12s;}
.leg:hover{background:#ffffff0a;}
.leg-dot{width:9px;height:9px;border-radius:2px;flex-shrink:0;}
.leg span{color:#556;font-size:9.5px;}

.edge-legend{display:flex;gap:6px;align-items:center;font-size:10px;color:#667;}
.el{display:flex;align-items:center;gap:4px;cursor:pointer;padding:3px 7px;border-radius:5px;opacity:0.35;transition:opacity 0.15s,background 0.15s;}
.el.active{opacity:1;}
.el:hover{background:#ffffff08;}
.el span{font-size:9.5px;color:#556;}

#controls{
	padding:5px 18px;
	background:linear-gradient(90deg,#09091f,#0c0c24);
	border-bottom:1px solid #141430;
	font-size:9.5px;color:#333;display:flex;gap:14px;align-items:center;flex-wrap:wrap;
}
#controls kbd{
	background:#111128;border:1px solid #1e1e42;padding:1px 6px;border-radius:3px;
	font-size:9px;color:#667;font-family:inherit;letter-spacing:0.02em;
}
#controls .hint-new{color:#3a5a9a;font-size:9px;background:#0a0a22;border:1px solid #1a2040;
	padding:1px 7px;border-radius:4px;}
#stats{margin-left:auto;color:#333;font-size:9.5px;}

#canvas-container{
	width:100%;height:calc(100vh - 70px);
	overflow:hidden;position:relative;
	transition:width 0.24s cubic-bezier(0.4,0,0.2,1);
}
#canvas-container.panel-open{width:calc(100% - 360px);}
canvas{display:block;width:100%;height:100%;cursor:grab;}
canvas.grabbing{cursor:grabbing!important;}
canvas.grab-group{cursor:move!important;}
canvas.node-drag{cursor:default!important;}

.tooltip{
	position:fixed;background:#0c0c28f0;color:#ccd;font-size:11px;
	padding:10px 14px;border-radius:9px;pointer-events:none;display:none;
	max-width:340px;z-index:300;border:1px solid #2a4070;
	box-shadow:0 6px 32px #0009,0 0 0 1px #2040600a;line-height:1.55;
	backdrop-filter:blur(8px);
}
.tooltip strong{color:#8ec5ff;display:block;margin-bottom:4px;font-size:12px;font-weight:700;}
.tooltip .meta{color:#556;font-size:9.5px;}
.tooltip .fn-list{margin-top:6px;color:#9ab;font-size:9.5px;line-height:1.9;}
.fn-tag{display:inline-block;background:#14203a;border:1px solid #1e304a;border-radius:3px;padding:0 5px;margin:1px;font-family:'Cascadia Code','Fira Code',monospace;font-size:8.5px;}
.fn-tag.caller{background:#221530;border-color:#3a2550;color:#cba6f7;}
.fn-tag.callee{background:#122a1a;border-color:#1e4a2a;color:#a6f7c1;}
.tooltip .rel{margin-top:5px;font-size:9.5px;}
.tooltip .rel.out{color:#7ab0f0;}
.tooltip .rel.imp{color:#7aeea0;}
.tooltip .rel.inc{color:#888;}
.tooltip .call-target{margin-top:5px;font-size:10px;color:#7ab0f0;font-weight:600;}
.tooltip .call-pairs{margin:2px 0 2px 4px;}
.tooltip .call-pair{font-size:9px;color:#889;line-height:1.7;}
.multi-def{color:#ffcc66;font-size:9px;}

#side-panel{
	position:fixed; top:0; right:0; bottom:0; width:360px;
	background:#09091ef8; border-left:1px solid #181840;
	box-shadow:-8px 0 32px #0009;
	z-index:30; display:none; flex-direction:column;
	font-size:12px; color:#ccd;
	backdrop-filter:blur(12px);
	transition:top 0.1s;
}
#side-panel.open{display:flex;}
#side-panel .sp-head{
	padding:14px 16px 12px; border-bottom:1px solid #181840;
	display:flex; align-items:flex-start; justify-content:space-between; gap:10px;
	background:linear-gradient(180deg,#0f0f2a,transparent);
}
#side-panel .sp-title{font-size:14px; font-weight:700; color:#e0f0ff; word-break:break-all;letter-spacing:0.01em;}
#side-panel .sp-meta{font-size:10px; color:#557; margin-top:4px;line-height:1.5;}
#side-panel .sp-close{
	cursor:pointer; color:#446; background:#10103a; border:1px solid #1c1c44;
	border-radius:6px; width:24px;height:24px;flex:none;
	display:flex;align-items:center;justify-content:center;font-size:13px;
	transition:all 0.12s;
}
#side-panel .sp-close:hover{color:#fff;background:#2a2a60;border-color:#3a3a70;}
#side-panel .sp-body{flex:1; overflow-y:auto; padding:12px 16px 24px;}
#side-panel .sp-body::-webkit-scrollbar{width:4px;}
#side-panel .sp-body::-webkit-scrollbar-track{background:transparent;}
#side-panel .sp-body::-webkit-scrollbar-thumb{background:#1e1e44;border-radius:2px;}
#side-panel .sp-section{margin-bottom:18px;}
#side-panel .sp-section h4{
	font-size:10px; text-transform:uppercase; letter-spacing:0.06em;
	color:#5a8ad0; margin-bottom:8px; display:flex; align-items:center; gap:7px;
	padding-bottom:5px; border-bottom:1px solid #111130;
}
#side-panel .sp-section h4 .cnt{
	background:#10103a; border:1px solid #1c1c44; border-radius:9px;
	padding:0 7px; font-size:9.5px; color:#7a9acc;
}
#side-panel .sp-empty{color:#334; font-size:10px; font-style:italic;padding:2px 0;}
#side-panel .sp-row{
	background:#0e0e28; border:1px solid #181840; border-radius:7px;
	padding:7px 10px; margin-bottom:5px; cursor:pointer;
	transition:background 0.12s, border-color 0.12s, transform 0.08s;
}
#side-panel .sp-row:hover{background:#151535; border-color:#2e2e60;transform:translateX(2px);}
#side-panel .sp-row .sp-file{font-size:11.5px; color:#bcd; font-weight:600;font-family:'Cascadia Code','Fira Code',monospace;font-size:11px;}
#side-panel .sp-row .sp-fns{font-size:9px; color:#446; margin-top:4px; line-height:1.7;}
#side-panel .sp-row .sp-fns .fn-tag{font-size:8.5px;}

/* Badge "liens masqués" dans le panneau */
.hidden-badge{
	display:inline-flex;align-items:center;gap:4px;
	background:#2a1020;border:1px solid #5a2040;border-radius:4px;
	padding:1px 7px;font-size:9px;color:#f08090;margin-top:6px;
}

.btn{
	background:linear-gradient(135deg,#1a2870,#223aaa);color:#cde;border:none;
	padding:4px 12px;border-radius:5px;cursor:pointer;font-size:10px;font-weight:500;
	box-shadow:0 2px 8px #0006;transition:all 0.15s;letter-spacing:0.02em;
}
.btn:hover{background:linear-gradient(135deg,#223aaa,#3a4acc);color:#fff;box-shadow:0 3px 12px #3a5acc44;}

#search-box{
	background:#0e0e28;border:1px solid #1e1e42;color:#bcd;
	padding:4px 10px;border-radius:5px;font-size:10px;width:140px;
	outline:none;transition:border-color 0.15s;
}
#search-box:focus{border-color:#3a5aaa;}
#search-box::placeholder{color:#223;}

/* Multi-sélection & alignement */
#align-bar{
	display:none;
	position:fixed;bottom:20px;left:50%;transform:translateX(-50%);
	background:linear-gradient(135deg,#0e0e30,#14143c);
	border:1px solid #2a3acc;border-radius:12px;
	padding:9px 18px;gap:10px;align-items:center;
	box-shadow:0 6px 32px #000b,0 0 0 1px #3a4acc22;
	z-index:200;font-size:11px;color:#9ab;
	animation:fadeInUp 0.18s cubic-bezier(0.2,0,0,1);
}
#align-bar.visible{display:flex;}
@keyframes fadeInUp{
	from{opacity:0;transform:translateX(-50%) translateY(12px);}
	to{opacity:1;transform:translateX(-50%) translateY(0);}
}
.ab-count{
	background:#131840;border:1px solid #3a4acc;border-radius:6px;
	padding:2px 10px;color:#7eb8f7;font-weight:700;font-size:12px;min-width:24px;text-align:center;
}
.ab-sep{width:1px;height:22px;background:#1e1e50;margin:0 4px;flex-shrink:0;}
.ab-label{color:#334;font-size:9.5px;white-space:nowrap;}
.ab-btn{
	background:#141840;color:#9ab;border:1px solid #2a3acc;
	padding:5px 13px;border-radius:7px;cursor:pointer;font-size:10.5px;font-weight:500;
	transition:all 0.12s;white-space:nowrap;display:flex;align-items:center;gap:5px;
}
.ab-btn:hover{background:#223acc;color:#fff;box-shadow:0 2px 10px #3a5acc44;}
.ab-btn.active{background:linear-gradient(135deg,#2a3acc,#3a4aee);color:#fff;border-color:#5a6aff;}
.ab-btn.clear{background:#160e20;border-color:#502040;color:#e07080;}
.ab-btn.clear:hover{background:#2a1030;color:#f0a0b0;}
</style>
</head>
<body>

<div id="header">
	<div>
		<h1>🔗 Game of Life — Carte des dépendances</h1>
		<p>Le-glitch-1-20-1/Code · Projet-C/game-of-life · 70 fichiers · 408 liens (recalculé depuis le code source)</p>
	</div>

	<div class="legend">
		<div class="leg"><div class="leg-dot" style="background:#1a3060;border:1px solid #2e75b6"></div><span>app</span></div>
		<div class="leg"><div class="leg-dot" style="background:#0e3018;border:1px solid #2e7b2e"></div><span>chunk</span></div>
		<div class="leg"><div class="leg-dot" style="background:#302010;border:1px solid #c8860a"></div><span>config</span></div>
		<div class="leg"><div class="leg-dot" style="background:#201040;border:1px solid #7a3fd6"></div><span>renderer</span></div>
		<div class="leg"><div class="leg-dot" style="background:#301808;border:1px solid #d4860b"></div><span>save</span></div>
		<div class="leg"><div class="leg-dot" style="background:#083020;border:1px solid #0a9b7e"></div><span>sim</span></div>
		<div class="leg"><div class="leg-dot" style="background:#300820;border:1px solid #d1267a"></div><span>ui</span></div>
	</div>
	<input id="search-box" placeholder="🔍 Fichier…" oninput="onSearch(this.value)">
	<button class="btn" onclick="resetView()">↺ Reset</button>
</div>

<div id="controls">
	<span><kbd>Molette</kbd> zoom</span>
	<span><kbd>Drag</kbd> pan</span>
	<span><kbd>Drag boîte</kbd> module</span>
	<span><kbd>Clic</kbd> sélectionner</span>
	<span><kbd>Clic fond</kbd> désélectionner</span>
	<span><kbd>Shift+Clic nœud sélectionné</kbd> masquer/afficher ses liens</span>
	<span><kbd>Shift+Clic autre nœud</kbd> multi-sélection</span>
	<div class="edge-legend" id="edge-legend">
		<div class="el active" data-etype="include" onclick="toggleEdgeType('include')"><svg width="30" height="10"><line x1="0" y1="5" x2="24" y2="5" stroke="#6699ff" stroke-width="2"/><polygon points="24,2 30,5 24,8" fill="#6699ff"/></svg> include</div>
		<div class="el active" data-etype="call" onclick="toggleEdgeType('call')"><svg width="30" height="10"><line x1="0" y1="5" x2="24" y2="5" stroke="#ffcc55" stroke-width="2"/><polygon points="24,2 30,5 24,8" fill="#ffcc55"/></svg> appel .c→.c</div>
		<div class="el active" data-etype="calls_h" onclick="toggleEdgeType('calls_h')"><svg width="30" height="10"><line x1="0" y1="5" x2="24" y2="5" stroke="#ff88aa" stroke-width="2"/><polygon points="24,2 30,5 24,8" fill="#ff88aa"/></svg> .c→.h appel</div>
		<div class="el active" data-etype="implements" onclick="toggleEdgeType('implements')"><svg width="30" height="10"><line x1="0" y1="5" x2="24" y2="5" stroke="#44ee99" stroke-width="2"/><polygon points="24,2 30,5 24,8" fill="#44ee99"/></svg> .c implémente .h</div>
		<div class="el active" data-etype="h_includes_h" onclick="toggleEdgeType('h_includes_h')"><svg width="30" height="10"><line x1="0" y1="5" x2="24" y2="5" stroke="#bb99ff" stroke-width="2"/><polygon points="24,2 30,5 24,8" fill="#bb99ff"/></svg> .h inclut .h</div>
	</div>
	<span id="stats"></span>
</div>

<div id="canvas-container">
	<canvas id="cv"></canvas>
</div>
<div class="tooltip" id="tooltip"></div>

<div id="side-panel">
	<div class="sp-head">
		<div>
			<div class="sp-title" id="sp-title"></div>
			<div class="sp-meta" id="sp-meta"></div>
		</div>
		<div class="sp-close" onclick="closeSidePanel()">✕</div>
	</div>
	<div class="sp-body" id="sp-body"></div>
</div>

<div id="align-bar">
	<span class="ab-count" id="ab-count">0</span>
	<span class="ab-label">sélectionnés · placer en ligne :</span>
	<div class="ab-sep"></div>
	<button class="ab-btn" id="ab-right"	onclick="lineUp('right')" >➡ Droite</button>
	<button class="ab-btn" id="ab-left"	 onclick="lineUp('left')"	>⬅ Gauche</button>
	<button class="ab-btn" id="ab-down"	 onclick="lineUp('down')"	>⬇ Bas</button>
	<button class="ab-btn" id="ab-up"		 onclick="lineUp('up')"		>⬆ Haut</button>
	<div class="ab-sep"></div>
	<button class="ab-btn clear" onclick="clearMultiSel()">✕</button>
</div>


<script>
const NODES_DATA = {"app.h": {"group": "app", "funcs": ["stamp_pattern", "draw_place_preview_cells", "draw_place_preview", "minmax_clear", "draw_selections_clear", "count_cells_in_rect", "minmax_copy", "draw_selections_copy", "draw_selections", "app_init_defaults", "app_init_undo", "app_cleanup", "app_init", "apply_zoom", "handle_pan_keys", "handle_pan_mouse", "handle_pan", "handle_drawing_start", "handle_drawing_move", "handle_drawing", "apply_random_fill", "get_clear_bounds", "clear_select_apply", "handle_clear_select", "get_copy_bounds", "copy_select_fill", "ctrl_paste", "handle_ctrl_shortcuts", "handle_no_ctrl_misc", "handle_no_ctrl_keys", "handle_escape", "handle_key_random", "handle_key_save", "handle_no_ctrl_clear", "handle_no_ctrl_center", "handle_no_ctrl", "handle_speed", "handle_game_input", "bresenham_sx", "bresenham_sy", "copy_select_apply", "handle_copy_select", "center_map_iter", "center_map", "rotate_chunk", "rotate_map_90", "get_center", "toolbar_act_clear", "toolbar_act_save", "toolbar_act_paste", "handle_toolbar_act1", "handle_toolbar_toggle", "fill_pop_buf", "draw_screen_game_hud", "draw_screen_game", "draw_screen_random_sel", "handle_toolbar_select", "handle_toolbar_act2", "handle_toolbar_action", "draw_screen_random", "draw_screen_save_zone_rect", "draw_screen_save_zone", "draw_screen_place_rotate", "draw_screen_place", "draw_screen_load", "draw_frame_menu", "draw_frame_screens", "draw_frame", "update", "push_undo", "pop_undo"], "includes": ["main.h", "chunk.h", "config.h", "renderer.h", "save.h", "simulation.h", "ui.h"], "is_header": true, "declared": ["stamp_pattern", "draw_place_preview_cells", "draw_place_preview", "minmax_clear", "draw_selections_clear", "count_cells_in_rect", "minmax_copy", "draw_selections_copy", "draw_selections", "app_init_defaults", "app_init_undo", "app_cleanup", "app_init", "apply_zoom", "handle_pan_keys", "handle_pan_mouse", "handle_pan", "handle_drawing_start", "handle_drawing_move", "handle_drawing", "apply_random